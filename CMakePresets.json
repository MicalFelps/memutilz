{
  "version": 9,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 28,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "cacheVariables": {
        "BUILD_SHARED_LIBS": false,
        "MEMUTILZ_BUILD_UI": true,
        "MEMUTILZ_FETCH_DEPS": true
      }
    },

    {
      "name": "windows-base",
      "hidden": true,
      "generator": "Visual Studio 17 2022",
      "inherits": "base",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "windows-x86",
      "inherits": "windows-base",
      "architecture": "Win32",
      "binaryDir": "${sourceDir}/build/intermediates/x86/",
      "displayName": "Windows x86 (MSVC)",
      "cacheVariables": {
        "ARCH": "x86"
      }
    },
    {
      "name": "windows-x64",
      "inherits": "windows-base",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build/intermediates/x64/",
      "displayName": "Windows x64 (MSVC)",
      "cacheVariables": {
        "ARCH": "x64"
      }
    },

    {
      "name": "linux-base",
      "hidden": true,
      "generator": "Ninja",
      "inherits": "base",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "linux-x86-debug",
      "inherits": "linux-base",
      "binaryDir": "${sourceDir}/build/intermediates/x86/Debug/",
      "displayName": "Linux x86 debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "ARCH": "x86"
      }
    },
    {
      "name": "linux-x86-release",
      "inherits": "linux-base",
      "binaryDir": "${sourceDir}/build/intermediates/x86/Release/",
      "displayName": "Linux x86 release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "ARCH": "x86"
      }
    },
    {
      "name": "linux-x64-debug",
      "inherits": "linux-base",
      "binaryDir": "${sourceDir}/build/intermediates/x64/Debug/",
      "displayName": "Linux x64 debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "ARCH": "x64"
      }
    },
    {
      "name": "linux-x64-release",
      "inherits": "linux-base",
      "binaryDir": "${sourceDir}/build/intermediates/x64/Release/",
      "displayName": "Linux x64 release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "ARCH": "x64"
      }
    }
  ],

  "buildPresets": [
    {
      "name": "windows-x86-debug",
      "configurePreset": "windows-x86",
      "configuration": "Debug"
    },
    {
      "name": "windows-x86-release",
      "configurePreset": "windows-x86",
      "configuration": "Release"
    },
    {
      "name": "windows-x64-debug",
      "configurePreset": "windows-x64",
      "configuration": "Debug"
    },
    {
      "name": "windows-x64-release",
      "configurePreset": "windows-x64",
      "configuration": "Release"
    },

    {
      "name": "linux-x86-debug",
      "configurePreset": "linux-x86-debug"
    },
    {
      "name": "linux-x86-release",
      "configurePreset": "linux-x86-release"
    },
    {
      "name": "linux-x64-debug",
      "configurePreset": "linux-x64-debug"
    },
    {
      "name": "linux-x64-release",
      "configurePreset": "linux-x64-release"
    }
  ]
}